# ConectaVacantes - Configuration
# Required: Get your API key from https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# LinkedIn Jobs - Alternative APIs (choose one for real job scraping)
# Apify: https://apify.com/fantastic-jobs/advanced-linkedin-job-search-api
APIFY_API_KEY=your_apify_api_key_here

# LoopCV: https://api-docs.loopcv.com/
LOOPCV_API_KEY=your_loopcv_api_key_here

# Firebase Configuration (for Firestore database)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Gmail API (for real email sending)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Application Settings
SECRET_KEY=your_secret_key_here
APP_URL=http://localhost:3000
PORT=3000
